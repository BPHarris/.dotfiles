#!/bin/sh
set -eu

alias config='/usr/bin/git --git-dir="$HOME"/.dotfiles/ --work-tree="$HOME"'

config push

config push origin live:master || {
	echo "unable to fast-forward origin/master to local live"
	exit 1
}

config fetch origin master:master || {
	echo "unable to fast-forward local master"
	exit 1
}
