{
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}"
  },

  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true,
    "max-length": 70
  },

  "custom/exit": {
    "format": "ï€‘",
    "tooltip-format": "Powermenu",
    "on-click": "wlogout -b 4",
    "tooltip": false
  },

  "custom/g703": {
    "exec": "~/.config/waybar/scripts/mouse_battery.sh",
    "return-type": "json",
    "interval": 30,
    "format": "{}",
    "on-click": "solaar"
  },

  "tray": {
    "icon-size": 14,
    "spacing": 8
  },

  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "َ°¥” {:%a %Y-%m-%d %H:%M}"
  },

  "cpu": {
    "format": "{usage:>3}% َ°» "
  },

  "memory": {
    "format": "{percentage:>3}% َ°چ›"
  },

  "disk": {
    "interval": 30,
    "format": "{percentage_used}% َ°‹ٹ",
    "path": "/",
    "on-click": "foot -e htop"
  },

  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/system",
      "disk",
      "cpu",
      "memory",
      "hyprland/language"
    ]
  },

  "network": {
    "format": "َ°–©",
    "format-disconnected": "َ°–ھ",
    "tooltip-format": "Network: {ifname} via {gwaddr}",
    "tooltip-format-wifi": "َ°–© {essid} ({signalStrength}%)\n{ipaddr}/{cidr}",
    "tooltip-format-ethernet": "َ°ˆ€ {ifname}\n{ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "foot -e nmtui"
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% َ°‚„",
    "format-plugged": "{capacity}% َ°ڑ¥",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "َ°‚ژ",
      "َ°پ؛",
      "َ°پ¼",
      "َ°پ¾",
      "َ°‚€"
    ]
  },

  "pulseaudio": {
    "scroll-step": 1,
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} ïٹ”",
    "format-bluetooth-muted": "َ°–پ ïٹ”",
    "format-muted": "َ°‌ں",
    "format-source": " {volume}% َ°چ¬",
    "format-source-muted": " َ°چ­",
    "format-icons": {
      "headphone": "َ°‹‹",
      "hands-free": "َ°‹ژ",
      "headset": "َ°‹ژ",
      "phone": "َ°ڈ²",
      "portable": "َ°ڈ²",
      "car": "َ°„‹",
      "default": [
        "َ°•؟",
        "َ°–€",
        "َ°•¾"
      ]
    },
    "on-click": "pavucontrol"
  },

  "bluetooth": {
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "َ°ˆˆ",
      "deactivated": "َ°ˆ‰"
    },
    "on-click-right": "hyprlock"
  }
}
