ACTION=="change", SUBSYSTEM=="power_supply", \
	ATTR{online}=="1", \
	ATTR{type}=="Mains", \
	RUN+="/usr/bin/powerprofilesctl set performance", \
	RUN+="/usr/bin/brightnessctl set 100%", \
	RUN+="/bin/sh -c 'for c in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do echo performance > $c; done'"
